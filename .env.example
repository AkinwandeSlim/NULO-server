# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# ============================================================================
# JWT CONFIGURATION (REQUIRED)
# ============================================================================
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# SMTP CONFIGURATION (REQUIRED - for email notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development
ENV=local

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,https://nulo-africa.vercel.app

# ============================================================================
# GOOGLE MAPS (OPTIONAL)
# ============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================================
# PAYSTACK PAYMENT GATEWAY (OPTIONAL)
# ============================================================================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ============================================================================
# TWILIO SMS CONFIGURATION (OPTIONAL)
# ============================================================================
TWILIO_ACCOUNT_SID=***************************
TWILIO_AUTH_TOKEN=***************************
TWILIO_MESSAGING_SERVICE_SID=***************************
TWILIO_FROM_NUMBER=***************************

# ============================================================================
# REDIS CONFIGURATION (OPTIONAL - for caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# INTERNAL SERVICE KEY (Optional - for protecting internal endpoints)
# ============================================================================
# NEXT_PUBLIC_INTERNAL_SERVICE_KEY=your-secret-key-here
BASE_URL=http://localhost:3000