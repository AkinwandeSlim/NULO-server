###############################################################################
# NuloAfrica x Nomba - full flow (collect -> reconcile -> disburse)
#
# HOW TO USE (free, no paid tool):
#   1. Install VS Code extension: "REST Client" (humao.rest-client)
#   2. Fill the @tokens below (see token howto at bottom)
#   3. Click the "Send Request" link that appears above each ### request
#   4. Run top-to-bottom. Response IDs chain automatically where possible.
#
# Agreement under test: 8b565c14 (SIGNED, Yaba, rent 990000, fee 0)
#   tenant   = mediaslim0705@gmail.com            -> {{tenantJwt}}
#   landlord = raphawellnessoptimization@gmail.com -> {{landlordJwt}}
###############################################################################

@baseUrl = http://localhost:8000/api/v1
@agreementId = 8b565c14-79f7-4b0d-b84f-19cfbb2b18e8

# Paste access_token from each user's browser localStorage (see bottom of file).
@tenantJwt = eyJhbGciOiJIUzI1NiIsImtpZCI6ImhIMld3aXlWUnd6SXBWNDQiLCJ0eXAiOiJKV1QifQ..a1icJkgiH3TysFKbglB96-cjsM5tbafH884SixsETZw
@landlordJwt = eyJhbGciOiJIUzI1NiIsImtpZCI6ImhIMld3aXlWUnd6SXBWNDQiLCJ0eXAiOiJKV1QifQ..-xK2lcdivUCEL7wFibrKYAC_JAgBg-9a_sg6Z6Dj4z0

# Webhook signatures: generate with
#   ./venv/Scripts/python.exe scripts/simulate_nomba_webhook.py 8b565c14-79f7-4b0d-b84f-19cfbb2b18e8 full_payment
# then paste the printed nomba-signature here (one per scenario).
@sigFull = 96n8z+rBJ872dk0Ep1+xB/RZoShlwhBwJism6Jcn+Vc=
@sigUnder = 6H6yPaRrVy5eFFZQp8q1uRUCzoujuECVHj+w2xLk7+s=
@sigOver = dXEpzssCzQvudgt/5E573PlX5SSrKYvZM06jZESGZRw=
@sigMisdir = PGHdIGjnXm1G+ke2xf2DzhKI+38BTXYmu2iL/aXBHFA=
@ts = 2026-07-01T10:00:00Z


### 0. Health (no auth)
GET http://localhost:8000/api/v1/health/nomba


### 1. Provision virtual account  (tenant or landlord JWT)
POST http://localhost:8000/api/v1/agreements/8b565c14-79f7-4b0d-b84f-19cfbb2b18e8/provision-nomba
Authorization: Bearer {{tenantJwt}}
Content-Type: application/json

{}


### 2. Payment status BEFORE  (expect reconciliation_status = PENDING)
GET http://localhost:8000/api/v1/agreements/8b565c14-79f7-4b0d-b84f-19cfbb2b18e8/payment-status
Authorization: Bearer {{tenantJwt}}


### 3. Webhook FULL payment  (paste body from simulator full_payment)
# Body MUST be the exact JSON the simulator printed for full_payment.
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: {{sigFull}}
nomba-timestamp: {{ts}}

< ./payloads/full_payment.json


### 4. Webhook REPLAY (idempotency -> already_processed)
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: {{sigFull}}
nomba-timestamp: {{ts}}

< ./payloads/full_payment.json


### 5. Webhook BAD signature -> 401
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: invalidsignature==
nomba-timestamp: {{ts}}

< ./payloads/full_payment.json


### 6. Webhook UNDERPAYMENT
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: {{sigUnder}}
nomba-timestamp: {{ts}}

< ./payloads/underpayment.json


### 7. Webhook OVERPAYMENT
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: {{sigOver}}
nomba-timestamp: {{ts}}

< ./payloads/overpayment.json


### 8. Webhook MISDIRECTED (unknown agreement)
POST http://localhost:8000/api/v1/webhooks/nomba/transfer
Content-Type: application/json
nomba-signature: {{sigMisdir}}
nomba-timestamp: {{ts}}

< ./payloads/misdirected.json


# @name statusAfter
### 9. Payment status AFTER  (expect FULL_PAYMENT; note transfer_history[0].id)
GET http://localhost:8000/api/v1/agreements/8b565c14-79f7-4b0d-b84f-19cfbb2b18e8/payment-status
Authorization: Bearer {{tenantJwt}}


### 10. Lookup + verify landlord bank  (landlord JWT)
POST http://localhost:8000/api/v1/disbursements/lookup-bank
Authorization: Bearer {{landlordJwt}}
Content-Type: application/json

{
  "account_number": "0000000000",
  "bank_code": "035"
}


# @name disburse
### 11. Disburse to landlord  (source_transfer_id auto-pulled from request 9)
POST http://localhost:8000/api/v1/agreements/8b565c14-79f7-4b0d-b84f-19cfbb2b18e8/disburse
Authorization: Bearer {{landlordJwt}}
Content-Type: application/json

{
  "source_transfer_id": "{{statusAfter.response.body.$.transfer_history[0].id}}",
  "retry_count": 0
}


### 12. Disbursement status  (merchant_tx_ref auto-pulled from request 11)
GET http://localhost:8000/api/v1/disbursements/{{disburse.response.body.$.merchant_tx_ref}}
Authorization: Bearer {{landlordJwt}}


###############################################################################
# TOKEN HOWTO (Google OAuth users have no password - grab the live token):
#   1. Log into the app in your browser as the user.
#   2. DevTools (F12) -> Console -> run:
#        JSON.parse(localStorage.getItem('sb-tqmjcygeykmbdjcfdbga-auth-token')).access_token
#   3. Copy the eyJ... string into @tenantJwt / @landlordJwt above.
#   Tokens expire ~1h; re-copy if you start getting 401s.
